{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/task-require-tests.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/require-venv.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/post-close-retro.sh"
          }
        ]
      }
    ]
  }
}
